# ─── Notion ───────────────────────────────────────────────────────────────────
# Internal integration token from https://www.notion.so/profile/integrations
# Starts with "ntn_" or "secret_"
NOTION_TOKEN=

# IDs of the four NVB databases.
# Get these from the database URL: notion.so/{workspace}/{DATABASE_ID}?v=...
# Run `pnpm validate-env` after filling these in to verify access.
NOTION_DB_INBOX=
NOTION_DB_EVIDENCE=
NOTION_DB_RUNS=
NOTION_DB_ARTIFACTS=

# Notion API version — pinned for determinism, do not change without testing
NOTION_API_VERSION=2022-06-28

# ─── Notion MCP (optional — enables MCP context retrieval at runtime) ──────────
#
# Set this to activate MCPContextProvider in the verdict pipeline.
# Without it, context retrieval uses the direct Notion API (always works).
#
# To start the MCP server on HTTP transport:
#   npx @notionhq/notion-mcp-server --transport http --port 3001
#
# Then set:
MCP_SERVER_URL=
# MCP_AUTH_TOKEN=   # Only if you started the server with --auth-token

# ─── LLM ──────────────────────────────────────────────────────────────────────
# Set ONE of these. The llm package auto-selects based on which key is present.
# Priority order: OPENAI_API_KEY → OPENROUTER_API_KEY
#
# Note: ANTHROPIC_API_KEY is NOT supported as a standalone provider.
# Native Anthropic client is not implemented — packages/llm/src/client.ts
# will throw if only ANTHROPIC_API_KEY is set.
# To use Claude: set OPENROUTER_API_KEY and set LLM_GENERATOR_MODEL=anthropic/claude-3-5-sonnet
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Model names — adjust for cost vs quality
LLM_GENERATOR_MODEL=gpt-4o
LLM_AUDITOR_MODEL=gpt-4o
LLM_CLERK_MODEL=gpt-4o-mini

# ─── GitHub (Optional) ────────────────────────────────────────────────────────
# Fine-grained PAT with issues:write on the target repo
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# ─── App ──────────────────────────────────────────────────────────────────────
WEBHOOK_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
